# Local Environment Variables (Protects your API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

