### =========================================================================
### 1. MULTI-USER REGISTRATION (Run once to populate DB)
### =========================================================================

# @name RegisterOwner
POST http://localhost:8080/api/v1/users/register
Content-Type: application/json

{
  "email": "alex@reform.app",
  "password": "securepassword123",
  "username": "Alex Owner"
}

###

# @name RegisterMember1
POST http://localhost:8080/api/v1/users/register
Content-Type: application/json

{
  "email": "bob@reform.app",
  "password": "securepassword123",
  "username": "Bob Collaborator"
}

###

# @name RegisterMember2
POST http://localhost:8080/api/v1/users/register
Content-Type: application/json

{
  "email": "charlie@reform.app",
  "password": "securepassword123",
  "username": "Charlie Collaborator"
}


### =========================================================================
### 2. AUTHENTICATION (Login to capture JWT Tokens)
### =========================================================================

# @name LoginAlex
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "username": "alex@reform.app",
  "password": "securepassword123"
}

> {% client.global.set("alexToken", response.body.accessToken); %}

###

# @name LoginBob
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "username": "bob@reform.app",
  "password": "securepassword123"
}

> {% client.global.set("bobToken", response.body.accessToken); %}

###

# @name LoginCharlie
POST http://localhost:8080/api/v1/auth/login
Content-Type: application/json

{
  "username": "charlie@reform.app",
  "password": "securepassword123"
}

> {% client.global.set("charlieToken", response.body.accessToken); %}


### =========================================================================
### 3. GLOBAL WORKSPACE ID VARIABLE
### =========================================================================
# Run 'Create Workspace' first, copy the workspace ID from the response, and paste it here:
@workspaceId = ed84124a-1800-491b-8c29-fe8b8df5b9d9


### =========================================================================
### 4. WORKSPACE CORE FLOW
### =========================================================================

# A. Create Workspace (Authenticated as Alex)
# @name CreateWorkspace
POST http://localhost:8080/api/v1/workspaces
Authorization: Bearer {{alexToken}}
Content-Type: application/json

{
  "name": "Alex Tech Team",
  "description": "Collaborative workspace for platform engineers"
}

###

# B. Get Workspace Details (Alex reads her own workspace)
GET http://localhost:8080/api/v1/workspaces/{{workspaceId}}
Authorization: Bearer {{alexToken}}

###

# C. Update Workspace Metadata (Alex updates properties)
PATCH http://localhost:8080/api/v1/workspaces/{{workspaceId}}
Authorization: Bearer {{alexToken}}
Content-Type: application/json

{
  "name": "Reform Core Platform Team",
  "description": "Enterprise-grade multi-tenant workspace"
}


### =========================================================================
### 5. TEAM MEMBERSHIP COLLABORATION FLOW
### =========================================================================

# D. Bulk-Add Members (Alex invites Bob and Charlie by email)
POST http://localhost:8080/api/v1/workspaces/{{workspaceId}}/members
Authorization: Bearer {{alexToken}}
Content-Type: application/json

{
  "emails": [
    "bob@reform.app",
    "charlie@reform.app"
  ]
}

###

# E. Verify Access (Bob can now read the workspace because he is a member)
GET http://localhost:8080/api/v1/workspaces/{{workspaceId}}
Authorization: Bearer {{bobToken}}

###

# F. Bulk-Remove Members (Alex kicks Bob out)
DELETE http://localhost:8080/api/v1/workspaces/{{workspaceId}}/members
Authorization: Bearer {{alexToken}}
Content-Type: application/json

{
  "emails": [
    "bob@reform.app"
  ]
}

###

# G. Final Security Verification (Bob tries to read but should get a 403 Forbidden now)
GET http://localhost:8080/api/v1/workspaces/{{workspaceId}}
Authorization: Bearer {{bobToken}}


### =========================================================================
### 6. FORM BUILDER: CREATE FORM
### =========================================================================
# Note: BuilderController's createForm mapping is @PostMapping(params = "title"),
# which means the "title" QUERY PARAM below is required just to route the request
# (separate from the "title" field in the JSON body).
# @PreAuthorize("@workspaceSecurity.isMember(authentication, #workspaceId)") checks the
# X-Workspace-Id HEADER; the service persists Form.workspaceId from the JSON BODY.
# Both must match the workspace you're actually a member of, so both are set to {{workspaceId}}.

# @name CreateForm
POST http://localhost:8080/api/v1/form?title=Customer%20Feedback
Authorization: Bearer {{alexToken}}
X-Workspace-Id: {{workspaceId}}
Content-Type: application/json

{
  "title": "Customer Feedback",
  "workspaceId": "{{workspaceId}}",
  "blocks": [
    {
      "type": "STATIC",
      "staticType": "SHORT_TEXT",
      "label": "What is your name?",
      "description": "Please enter your full name",
      "required": true,
      "sortOrder": 1,
      "placeholder": "e.g. Jane Doe",
      "maxChar": 50
    }
  ]
}

> {% client.global.set("formId", response.body.id); %}


### =========================================================================
### 7. FORM BUILDER: READ, UPDATE, DELETE
### =========================================================================

# H. Get Single Form (requires the workspace-scoped X-Workspace-Id header)
# @name GetForm
GET http://localhost:8080/api/v1/form/{{formId}}
Authorization: Bearer {{alexToken}}
X-Workspace-Id: {{workspaceId}}

###

# I. Get All Forms In Workspace
# @name GetAllForms
GET http://localhost:8080/api/v1/form
Authorization: Bearer {{alexToken}}
X-Workspace-Id: {{workspaceId}}

###

# J. Update Form Blocks (PUT /{id}/blocks — replaces the full blocks list)
# @name UpdateFormBlocks
PUT http://localhost:8080/api/v1/form/{{formId}}/blocks
Authorization: Bearer {{bobToken}}
X-Workspace-Id: {{workspaceId}}
Content-Type: application/json

{
  "id": "{{formId}}",
  "workspaceId": "{{workspaceId}}",
  "blocks": [
    {
      "type": "STATIC",
      "staticType": "SHORT_TEXT",
      "label": "What is your full name?",
      "description": "Please enter your full name: ",
      "required": true,
      "sortOrder": 1,
      "placeholder": "e.g. Jane Doe",
      "maxChar": 50
    },
    {
      "type": "STATIC",
      "staticType": "EMAIL",
      "label": "What is your email?",
      "description": "We'll use this to follow up",
      "required": true,
      "sortOrder": 2,
      "placeholder": "e.g. jane@example.com"
    }
  ]
}

> {% client.global.set("formSlug", response.body.slug);
     client.global.set("block1Id", response.body.blocks[0].id);
     client.global.set("block2Id", response.body.blocks[1].id); %}

###

# K. Delete Form (expect 204 No Content)
# @name DeleteForm
DELETE http://localhost:8080/api/v1/form/{{formId}}
Authorization: Bearer {{bobToken}}
X-Workspace-Id: {{workspaceId}}


### =========================================================================
### 8. SUBMISSION MODULE
### =========================================================================
# /api/v1/f/** and /api/v1/submissions/** are anonymous by design (SecurityConfig
# permitAll's both) — no Authorization header on the truly public requests below,
# to actually prove that.

# L. Publish Form (Alex is the creator — required before any submission can succeed)
# @name PublishForm
PATCH http://localhost:8080/api/v1/form/{{formId}}/publish
Authorization: Bearer {{alexToken}}
X-Workspace-Id: {{workspaceId}}

###

# M. Publish Attempt By Non-Creator (Charlie is a member but didn't create this form — expect 403 Forbidden)
# @name PublishFormForbidden
PATCH http://localhost:8080/api/v1/form/{{formId}}/publish
Authorization: Bearer {{bobToken}}
X-Workspace-Id: {{workspaceId}}

###

# N. Public Get Form Definition — anonymous request, no token (expect 200)
# @name GetPublicForm
GET http://localhost:8080/api/v1/f/{{formSlug}}

###

# O. Successful Submission — anonymous request, both required blocks filled (expect 200, {message, id})
# @name SubmitFormSuccess
POST http://localhost:8080/api/v1/submissions/{{formSlug}}
Content-Type: application/json

{
  "{{block1Id}}": "Jane Doe",
  "{{block2Id}}": "jane@example.com"
}

###

# P. Required Field Blank — block1 present but empty string (expect 400, "Field cannot be empty")
# @name SubmitFormBlankRequiredField
POST http://localhost:8080/api/v1/submissions/{{formSlug}}
Content-Type: application/json

{
  "{{block1Id}}": "",
  "{{block2Id}}": "jane@example.com"
}

###

# Q. Required Field Omitted Entirely — block1 key missing from the JSON, not just blank
# (expect 400, same "Field cannot be empty" message as P — answers.path(key) treats
# a missing key and a blank value identically)
# @name SubmitFormMissingRequiredKey
POST http://localhost:8080/api/v1/submissions/{{formSlug}}
Content-Type: application/json

{
  "{{block2Id}}": "jane@example.com"
}

###

# R. Submission To Nonexistent Slug (expect 404, "Form does not exist")
# @name SubmitFormBadSlug
POST http://localhost:8080/api/v1/submissions/this-slug-does-not-exist-000000
Content-Type: application/json

{
  "{{block1Id}}": "Jane Doe"
}

###

# S. Create A Second Form, Deliberately Never Published (fixture for tests T & U below)
# @name CreateDraftOnlyForm
POST http://localhost:8080/api/v1/form?title=Draft%20Only
Authorization: Bearer {{alexToken}}
X-Workspace-Id: {{workspaceId}}
Content-Type: application/json

{
  "title": "Draft Only",
  "workspaceId": "{{workspaceId}}",
  "blocks": [
    {
      "type": "STATIC",
      "staticType": "SHORT_TEXT",
      "label": "Anything?",
      "required": false,
      "sortOrder": 1
    }
  ]
}

> {% client.global.set("draftFormSlug", response.body.slug); %}

###

# T. Public Get A Still-DRAFT Form's Definition (expect 400, "Form is not published!")
# @name GetPublicDraftForm
GET http://localhost:8080/api/v1/f/{{draftFormSlug}}

###

# U. Submission To A Still-DRAFT Form (expect 400, "The form is not published.")
# @name SubmitFormStillDraft
POST http://localhost:8080/api/v1/submissions/{{draftFormSlug}}
Content-Type: application/json

{}

